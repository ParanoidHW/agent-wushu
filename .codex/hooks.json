{
  "hooks": {
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/python3 \"$(git rev-parse --show-toplevel)/hooks/hooks/save_compact_tasks.py\" -o compact-task-state.md --state-file .compact-task-state.json --quiet",
            "timeout": 30,
            "statusMessage": "Saving compact task state"
          }
        ]
      }
    ]
  }
}
