{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-kb.local/schema/repository-profile-1.0.0.json",
  "title": "Research Knowledge Repository Profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["profile_version", "profile_id", "compatible_organization_schema_major"],
  "properties": {
    "profile_version": {"const": "1.0.0"},
    "profile_id": {"type": "string", "minLength": 1},
    "compatible_organization_schema_major": {"const": 1},
    "policy_documents": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "pattern": "^(?!/).+"}
    },
    "domain_patterns": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "overrides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "process_root": {"type": "string", "minLength": 1, "pattern": "^(?!/).+"},
        "domain_entry": {"type": "string", "minLength": 1, "pattern": "^(?!/).+"},
        "document_paths": {"type": "object", "additionalProperties": {"type": "string", "minLength": 1}},
        "asset_paths": {"type": "object", "additionalProperties": false, "properties": {"root": {"type": "string"}, "survey_template": {"type": "string"}, "paper_template": {"type": "string"}}},
        "process_only_kinds": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "relationships": {"type": "object", "additionalProperties": false, "properties": {"domain_entry_indexes": {"type": "array", "items": {"type": "string"}}, "survey_links_to": {"type": "array", "items": {"type": "string"}}, "paper_backlinks_to_any": {"type": "array", "items": {"type": "string"}}, "paper_backlinks_to_all": {"type": "array", "items": {"type": "string"}}}},
        "formal_forbidden_patterns": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
        "validation": {"type": "object", "additionalProperties": false, "properties": {"require_relative_links": {"type": "boolean"}, "require_git_tracked_assets": {"type": "boolean"}, "check_orphan_documents": {"type": "boolean"}, "check_orphan_assets": {"type": "boolean"}, "relationship_block_style": {"enum": ["none", "markdown", "obsidian-callout", "repository-policy"]}}}
      }
    }
  }
}
